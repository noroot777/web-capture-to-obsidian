# Copy this file to x_bookmarks_to_obsidian.env and adjust the values for your machine.

# Where the generated Obsidian notes should be written.
# Must be an absolute path.
X_BOOKMARKS_TO_OBSIDIAN_TARGET_DIR="$HOME/Obsidian/X Bookmarks to Obsidian"

# Optional: override the Chrome binary path.
# X_BOOKMARKS_TO_OBSIDIAN_CHROME_BIN="/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"

# Optional: override the DevToolsActivePort file path if you use a different Chrome profile.
# X_BOOKMARKS_TO_OBSIDIAN_DEVTOOLS_FILE="$HOME/Library/Application Support/Google/Chrome/DevToolsActivePort"

# Optional: override the timezone used when rendering note timestamps.
# X_BOOKMARKS_TO_OBSIDIAN_TIMEZONE="Asia/Shanghai"
